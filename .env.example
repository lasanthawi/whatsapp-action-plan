# OpenAI
OPENAI_API_KEY=sk-proj-replace-me
ENABLE_AUTO_REPLY_AGENT=true
# CHAT_AGENT_MODEL=gpt-4o-mini

# Neon Auth
NEON_AUTH_COOKIE_SECRET=replace-with-a-strong-random-secret
NEON_AUTH_BASE_URL=https://your-neon-auth-url.example.com/neondb/auth

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-your-supabase-service-role-key

# WhatsApp
WHATSAPP_ACCESS_TOKEN=replace-with-your-whatsapp-access-token
WHATSAPP_PHONE_ID=replace-with-your-phone-number-id
WHATSAPP_RECIPIENT_PHONE=94700000000
WHATSAPP_VERIFY_TOKEN=replace-with-your-webhook-verify-token

# Composio
COMPOSIO_API_KEY=replace-with-your-composio-api-key
COMPOSIO_CALLBACK_BASE_URL=https://your-app.vercel.app
# Optional if you later verify Composio webhooks
COMPOSIO_WEBHOOK_SECRET=replace-with-your-composio-webhook-secret

# Cron
CRON_SECRET=replace-with-a-random-secret
